# Ignore binary assets
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.svg
**/*.webp
**/*.ico
**/*.ttf
**/*.otf
**/*.woff
**/*.woff2

# Ignore build and cache directories
.gradle/
build/
app/build/
datamodel/build/
tools/build/
.kotlin/
.ruby-lsp/
.specify/

# Ignore IDE metadata
.idea/
*.iml
*.iws
*.ipr

# Ignore version control
.git/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore large/noisy files that are likely low signal for code analysis
**/*.bin
**/*.zip
**/*.gz
**/*.tar
**/*.rar
