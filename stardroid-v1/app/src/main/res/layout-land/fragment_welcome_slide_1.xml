<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- CLEAN BACKGROUND -->
    <ImageView
        android:id="@+id/screenshot_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/tutorial_bg_clean" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000" />

    <!-- ========================================== -->
    <!-- REAL UI SKELETON                           -->
    <!-- ========================================== -->

    <!-- LEFT SIDEBAR BACKGROUND -->
    <View
        android:id="@+id/left_sidebar_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/sidebarnoelements"
        app:layout_constraintStart_toStartOf="@+id/icon_horizon"
        app:layout_constraintEnd_toEndOf="@+id/icon_horizon"
        app:layout_constraintTop_toTopOf="@+id/icon_stars"
        app:layout_constraintBottom_toBottomOf="@+id/icon_horizon" />

    <!-- Vertical icon chain (compressed for landscape) -->
    <ImageView android:id="@+id/icon_stars" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingLeft="5dp" android:paddingTop="8dp" android:paddingBottom="6dp" android:paddingRight="10dp" android:src="@drawable/star_on" android:layout_marginStart="12dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@+id/icon_constellations" app:layout_constraintVertical_chainStyle="packed" />
    <ImageView android:id="@+id/icon_constellations" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingLeft="5dp" android:paddingTop="5dp" android:paddingBottom="5dp" android:paddingRight="10dp" android:src="@drawable/stars_on" android:layout_marginStart="12dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/icon_stars" app:layout_constraintBottom_toTopOf="@+id/icon_deep_sky" />
    <ImageView android:id="@+id/icon_deep_sky" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingLeft="5dp" android:paddingTop="5dp" android:paddingBottom="5dp" android:paddingRight="10dp" android:src="@drawable/deep_sky_objects_on" android:layout_marginStart="12dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/icon_constellations" app:layout_constraintBottom_toTopOf="@+id/icon_planets" />
    <ImageView android:id="@+id/icon_planets" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingLeft="5dp" android:paddingTop="5dp" android:paddingBottom="5dp" android:paddingRight="10dp" android:src="@drawable/planet_on" android:layout_marginStart="12dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/icon_deep_sky" app:layout_constraintBottom_toTopOf="@+id/icon_meteors" />
    <ImageView android:id="@+id/icon_meteors" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingLeft="5dp" android:paddingTop="5dp" android:paddingBottom="5dp" android:paddingRight="10dp" android:src="@drawable/b_meteor_on" android:layout_marginStart="12dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/icon_planets" app:layout_constraintBottom_toTopOf="@+id/icon_grid" />
    <ImageView android:id="@+id/icon_grid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingLeft="5dp" android:paddingTop="5dp" android:paddingBottom="5dp" android:paddingRight="10dp" android:src="@drawable/grid_on" android:layout_marginStart="12dp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/icon_meteors" app:layout_constraintBottom_toTopOf="@+id/icon_horizon" />
    <ImageView
        android:id="@+id/icon_horizon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="5dp"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:paddingEnd="10dp"
        android:src="@drawable/horizon_on"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/icon_grid"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Right side icons (top bar) -->
    <ImageView
        android:id="@+id/icon_manual_auto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/automaticmode"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView android:id="@+id/icon_search" android:layout_width="40dp" android:layout_height="40dp" android:padding="8dp" android:scaleType="centerInside" android:src="@android:drawable/ic_menu_search" android:layout_marginTop="8dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintHorizontal_bias="1.0" app:layout_constraintEnd_toStartOf="@+id/icon_night_mode" app:layout_constraintHorizontal_chainStyle="packed" />
    <ImageView android:id="@+id/icon_night_mode" android:layout_width="40dp" android:layout_height="40dp" android:padding="8dp" android:scaleType="centerInside" android:src="@android:drawable/ic_menu_view" android:layout_marginTop="8dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@+id/icon_search" app:layout_constraintEnd_toStartOf="@+id/icon_time_travel" />
    <ImageView android:id="@+id/icon_time_travel" android:layout_width="40dp" android:layout_height="40dp" android:padding="8dp" android:scaleType="centerInside" android:src="@drawable/time_travel_icon" android:layout_marginTop="8dp" android:layout_marginEnd="12dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@+id/icon_night_mode" app:layout_constraintEnd_toEndOf="parent" />

    <!-- Explanatory Text at Bottom (compact for landscape) -->
    <LinearLayout
        android:id="@+id/bottom_text_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#DD0B0F19"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/warm_welcome_slide1_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/warm_welcome_slide1_title"
            android:textSize="18sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/warm_welcome_slide1_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/warm_welcome_slide1_desc"
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <!-- ========================================== -->
    <!-- HIGHLIGHT GROUPS (selected, repositioned)  -->
    <!-- ========================================== -->

    <!-- STARS -->
    <ImageView android:id="@+id/ring_stars" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_neon_ring" app:layout_constraintBottom_toBottomOf="@id/icon_stars" app:layout_constraintEnd_toEndOf="@id/icon_stars" app:layout_constraintStart_toStartOf="@id/icon_stars" app:layout_constraintTop_toTopOf="@id/icon_stars" />
    <ImageView android:id="@+id/arrow_stars" android:layout_width="80dp" android:layout_height="20dp" android:src="@drawable/ic_neon_arrow_long" android:transformPivotX="0dp" android:transformPivotY="10dp" android:rotation="-30" app:layout_constraintBottom_toBottomOf="@id/ring_stars" app:layout_constraintStart_toEndOf="@id/ring_stars" app:layout_constraintTop_toTopOf="@id/ring_stars" />
    <TextView android:id="@+id/text_stars" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/show_stars_pref" android:textColor="#00FFFF" android:textStyle="bold" android:textSize="12sp" android:shadowColor="#00FFFF" android:shadowDx="0" android:shadowDy="0" android:shadowRadius="12" android:background="@drawable/neon_text_bg"
        android:paddingHorizontal="8dp" android:paddingVertical="3dp" app:layout_constraintStart_toEndOf="@id/arrow_stars" app:layout_constraintTop_toTopOf="@id/arrow_stars"
        android:layout_marginStart="0dp" android:translationX="-12dp" android:translationY="-40dp" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_stars" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_stars,arrow_stars,text_stars" />

    <!-- CONSTELLATIONS -->
    <ImageView android:id="@+id/ring_constellations" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_neon_ring" app:layout_constraintBottom_toBottomOf="@id/icon_constellations" app:layout_constraintEnd_toEndOf="@id/icon_constellations" app:layout_constraintStart_toStartOf="@id/icon_constellations" app:layout_constraintTop_toTopOf="@id/icon_constellations" />
    <ImageView android:id="@+id/arrow_constellations" android:layout_width="80dp" android:layout_height="20dp" android:src="@drawable/ic_neon_arrow_long" android:transformPivotX="0dp" android:transformPivotY="10dp" android:rotation="-20" app:layout_constraintBottom_toBottomOf="@id/ring_constellations" app:layout_constraintStart_toEndOf="@id/ring_constellations" app:layout_constraintTop_toTopOf="@id/ring_constellations" />
    <TextView android:id="@+id/text_constellations" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/show_constellations_pref" android:textColor="#00FFFF" android:textStyle="bold" android:textSize="12sp" android:shadowColor="#00FFFF" android:shadowDx="0" android:shadowDy="0" android:shadowRadius="12" android:background="@drawable/neon_text_bg"
        android:paddingHorizontal="8dp" android:paddingVertical="3dp" app:layout_constraintStart_toEndOf="@id/arrow_constellations" app:layout_constraintTop_toTopOf="@id/arrow_constellations"
        android:layout_marginStart="0dp" android:translationX="-8dp" android:translationY="-28dp" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_constellations" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_constellations,arrow_constellations,text_constellations" />

    <!-- PLANETS -->
    <ImageView android:id="@+id/ring_planets" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_neon_ring" app:layout_constraintBottom_toBottomOf="@id/icon_planets" app:layout_constraintEnd_toEndOf="@id/icon_planets" app:layout_constraintStart_toStartOf="@id/icon_planets" app:layout_constraintTop_toTopOf="@id/icon_planets" />
    <ImageView android:id="@+id/arrow_planets" android:layout_width="80dp" android:layout_height="20dp" android:src="@drawable/ic_neon_arrow_long" android:transformPivotX="0dp" android:transformPivotY="10dp" android:rotation="0" app:layout_constraintBottom_toBottomOf="@id/ring_planets" app:layout_constraintStart_toEndOf="@id/ring_planets" app:layout_constraintTop_toTopOf="@id/ring_planets" />
    <TextView android:id="@+id/text_planets" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tutorial_planets" android:textColor="#00FFFF" android:textStyle="bold" android:textSize="12sp" android:shadowColor="#00FFFF" android:shadowDx="0" android:shadowDy="0" android:shadowRadius="12" android:background="@drawable/neon_text_bg"
        android:paddingHorizontal="8dp" android:paddingVertical="3dp" app:layout_constraintStart_toEndOf="@id/arrow_planets" app:layout_constraintTop_toTopOf="@id/arrow_planets"
        android:layout_marginStart="0dp" android:translationX="-4dp" android:translationY="-3dp" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_planets" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_planets,arrow_planets,text_planets" />

    <!-- METEORS -->
    <ImageView android:id="@+id/ring_meteors" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_neon_ring" app:layout_constraintBottom_toBottomOf="@id/icon_meteors" app:layout_constraintEnd_toEndOf="@id/icon_meteors" app:layout_constraintStart_toStartOf="@id/icon_meteors" app:layout_constraintTop_toTopOf="@id/icon_meteors" />
    <ImageView android:id="@+id/arrow_meteors" android:layout_width="80dp" android:layout_height="20dp" android:src="@drawable/ic_neon_arrow_long" android:transformPivotX="0dp" android:transformPivotY="10dp" android:rotation="10" app:layout_constraintBottom_toBottomOf="@id/ring_meteors" app:layout_constraintStart_toEndOf="@id/ring_meteors" app:layout_constraintTop_toTopOf="@id/ring_meteors" />
    <TextView android:id="@+id/text_meteors" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tutorial_meteors" android:textColor="#00FFFF" android:textStyle="bold" android:textSize="12sp" android:shadowColor="#00FFFF" android:shadowDx="0" android:shadowDy="0" android:shadowRadius="12" android:background="@drawable/neon_text_bg"
        android:paddingHorizontal="8dp" android:paddingVertical="3dp" app:layout_constraintStart_toEndOf="@id/arrow_meteors" app:layout_constraintTop_toTopOf="@id/arrow_meteors"
        android:layout_marginStart="0dp" android:translationX="-6dp" android:translationY="8dp" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_meteors" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_meteors,arrow_meteors,text_meteors" />

    <!-- GRID -->
    <ImageView android:id="@+id/ring_grid" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_neon_ring" app:layout_constraintBottom_toBottomOf="@id/icon_grid" app:layout_constraintEnd_toEndOf="@id/icon_grid" app:layout_constraintStart_toStartOf="@id/icon_grid" app:layout_constraintTop_toTopOf="@id/icon_grid" />
    <ImageView android:id="@+id/arrow_grid" android:layout_width="80dp" android:layout_height="20dp" android:src="@drawable/ic_neon_arrow_long" android:transformPivotX="0dp" android:transformPivotY="10dp" android:rotation="20" app:layout_constraintBottom_toBottomOf="@id/ring_grid" app:layout_constraintStart_toEndOf="@id/ring_grid" app:layout_constraintTop_toTopOf="@id/ring_grid" />
    <TextView android:id="@+id/text_grid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tutorial_grid" android:textColor="#00FFFF" android:textStyle="bold" android:textSize="12sp" android:shadowColor="#00FFFF" android:shadowDx="0" android:shadowDy="0" android:shadowRadius="12" android:background="@drawable/neon_text_bg"
        android:paddingHorizontal="8dp" android:paddingVertical="3dp" app:layout_constraintStart_toEndOf="@id/arrow_grid" app:layout_constraintTop_toTopOf="@id/arrow_grid"
        android:layout_marginStart="0dp" android:translationX="-9dp" android:translationY="16dp" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_grid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_grid,arrow_grid,text_grid" />

    <!-- HORIZON -->
    <ImageView android:id="@+id/ring_horizon" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_neon_ring" app:layout_constraintBottom_toBottomOf="@id/icon_horizon" app:layout_constraintEnd_toEndOf="@id/icon_horizon" app:layout_constraintStart_toStartOf="@id/icon_horizon" app:layout_constraintTop_toTopOf="@id/icon_horizon" />
    <ImageView android:id="@+id/arrow_horizon" android:layout_width="80dp" android:layout_height="20dp" android:src="@drawable/ic_neon_arrow_long" android:transformPivotX="0dp" android:transformPivotY="10dp" android:rotation="30" app:layout_constraintBottom_toBottomOf="@id/ring_horizon" app:layout_constraintStart_toEndOf="@id/ring_horizon" app:layout_constraintTop_toTopOf="@id/ring_horizon" />
    <TextView android:id="@+id/text_horizon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/show_horizon_pref" android:textColor="#00FFFF" android:textStyle="bold" android:textSize="12sp" android:shadowColor="#00FFFF" android:shadowDx="0" android:shadowDy="0" android:shadowRadius="12" android:background="@drawable/neon_text_bg"
        android:paddingHorizontal="8dp" android:paddingVertical="3dp" app:layout_constraintStart_toEndOf="@id/arrow_horizon" app:layout_constraintTop_toTopOf="@id/arrow_horizon"
        android:layout_marginStart="0dp" android:translationX="-14dp" android:translationY="28dp" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_horizon" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_horizon,arrow_horizon,text_horizon" />

    <!-- DEEP SKY (hidden in landscape - not enough space) -->
    <ImageView android:id="@+id/ring_deep_sky" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/arrow_deep_sky" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/text_deep_sky" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_deep_sky" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_deep_sky,arrow_deep_sky,text_deep_sky" />

    <!-- SEARCH (hidden in landscape - not enough space) -->
    <ImageView android:id="@+id/ring_search" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/arrow_search" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/text_search" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_search" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_search,arrow_search,text_search" />

    <!-- NIGHT MODE (hidden in landscape - not enough space) -->
    <ImageView android:id="@+id/ring_night_mode" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/arrow_night_mode" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/text_night_mode" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_night_mode" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_night_mode,arrow_night_mode,text_night_mode"/>

    <!-- TIME TRAVEL (hidden in landscape - not enough space) -->
    <ImageView android:id="@+id/ring_time_travel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/arrow_time_travel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/text_time_travel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_time_travel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_time_travel,arrow_time_travel,text_time_travel" />

    <!-- MANUAL/AUTO (hidden in landscape - not enough space) -->
    <ImageView android:id="@+id/ring_manual_auto" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <ImageView android:id="@+id/arrow_manual_auto" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <TextView android:id="@+id/text_manual_auto" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <androidx.constraintlayout.widget.Group android:id="@+id/highlight_manual_auto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" app:constraint_referenced_ids="ring_manual_auto,arrow_manual_auto,text_manual_auto" />

</androidx.constraintlayout.widget.ConstraintLayout>
